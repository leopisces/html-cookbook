          "code": "<!--\n  title: JavaScript DOM 操作\n  description: DOM基础操作：选取元素、修改内容、添加事件\n  goals: getElementById/querySelector; 修改textContent/style; addEventListener\n  tags: javascript, dom\n-->\n<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>JavaScript DOM 操作</title>\n  <style>\n    body { font-family: sans-serif; max-width: 600px; margin: 2rem auto; padding: 1rem; }\n    .btn { background: #059669; color: white; padding: 0.5rem 1rem; border: none; border-radius: 4px; cursor: pointer; margin-right: 0.5rem; }\n    #output { background: #f1f5f9; padding: 1rem; border-radius: 6px; margin-top: 1rem; min-height: 60px; }\n  </style>\n</head>\n<body>\n  <h1>JavaScript DOM 操作</h1>\n  <button class=\"btn\" onclick=\"changeText()\">修改文字</button>\n  <button class=\"btn\" onclick=\"changeColor()\">修改颜色</button>\n  <button class=\"btn\" onclick=\"addItem()\">添加元素</button>\n  <div id=\"output\">点击按钮查看效果</div>\n  <script>\n    function changeText() {\n      document.getElementById('output').textContent = '文字已修改！';\n    }\n    function changeColor() {\n      document.getElementById('output').style.background = '#d1fae5';\n    }\n    function addItem() {\n      const p = document.createElement('p');\n      p.textContent = '新增的段落';\n      document.getElementById('output').appendChild(p);\n    }\n  </script>\n</body>\n</html>",
